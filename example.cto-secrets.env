# Example secrets file. Copy to ~/.cto-secrets.env on the machine that will run
# scripts/install.sh (your laptop, or an existing CTO instance), populate the
# values, and chmod 0600 it. Do NOT commit a populated copy — ~/.cto-secrets.env
# lives outside the repo by default. *.env is gitignored as a backstop.
#
# Required:
HETZNER_API_TOKEN=
# GITHUB_TOKEN can be left blank if `gh auth status` is logged in — the script
# will use `gh auth token` automatically.
GITHUB_TOKEN=

# Optional but recommended:
OPENAI_API_KEY=          # for engram / Hermes embeddings
OPENROUTER_API_KEY=      # LLM fallback if Codex OAuth is throttled
BRAVE_API_KEY=           # Brave search MCP (without this, brave-search fails)

# Auto-generated if absent — set explicitly to keep stable across re-installs:
# HERMES_API_SERVER_KEY=

# Optional overrides:
# CTO_SECRETS=~/.cto-secrets.env     # path to this file
# SSH_KEY=~/.ssh/cto-deploy           # local private key matching the Hetzner SSH key
# HETZNER_SSH_KEY_NAME=cto-agent-deploy  # name of the public key registered in Hetzner
# VPS_LOCATION=nbg1                   # nbg1 | fsn1 | hel1 | ash | hil | sin
# VPS_NAME=cto-vN                     # auto-increments from existing cto-vN servers
# REPO_URL=https://github.com/johnjhusband/CTO.git
